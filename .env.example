# ---- Auth.js / NextAuth ----
# Gere com: openssl rand -base64 32  (ou: npx auth secret)
AUTH_SECRET=

# Em produção a Vercel define AUTH_URL automaticamente; localmente:
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# E em produção: https://SEU-DOMINIO.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Neon Postgres ----
# Vercel Marketplace → Storage → Neon → connect → auto-popula DATABASE_URL
# Localmente, rode: vercel env pull .env.local
DATABASE_URL=
